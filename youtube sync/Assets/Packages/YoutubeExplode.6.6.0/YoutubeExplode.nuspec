<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>YoutubeExplode</id>
    <version>6.6.0</version>
    <authors>Tyrrrz</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>favicon.png</icon>
    <projectUrl>https://github.com/Tyrrrz/YoutubeExplode</projectUrl>
    <description>Abstraction layer over YouTube's internal API. Note: this package has limited availability in Russia and Belarus.</description>
    <releaseNotes>https://github.com/Tyrrrz/YoutubeExplode/releases</releaseNotes>
    <copyright>Copyright (C) Oleksii Holub</copyright>
    <tags>youtube video download playlist user channel closed caption tracks subtitles parse extract metadata info net core standard</tags>
    <repository type="git" url="https://github.com/Tyrrrz/YoutubeExplode" commit="79aee02327a09b460d229b4e633601cffb9b77a1" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="AngleSharp" version="1.4.0" exclude="Build,Analyzers" />
        <dependency id="JsonExtensions" version="1.2.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net7.0">
        <dependency id="AngleSharp" version="1.4.0" exclude="Build,Analyzers" />
        <dependency id="JsonExtensions" version="1.2.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="AngleSharp" version="1.4.0" exclude="Build,Analyzers" />
        <dependency id="JsonExtensions" version="1.2.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="AngleSharp" version="1.4.0" exclude="Build,Analyzers" />
        <dependency id="JsonExtensions" version="1.2.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="10.0.5" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="9.0.2" exclude="Build,Analyzers" />
        <dependency id="System.Threading.Tasks.Extensions" version="4.6.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>